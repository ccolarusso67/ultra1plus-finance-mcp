<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>U1PFinanceSync</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- QBFC SDK - QuickBooks Desktop SDK COM interop -->
    <!-- Install QBFC16 SDK from Intuit, then add reference:
         Right-click References > Add COM Reference > Interop.QBFC16Lib -->

    <!-- PostgreSQL -->
    <PackageReference Include="Npgsql" Version="8.0.6" />

    <!-- SOAP for Web Connector -->
    <PackageReference Include="SoapCore" Version="1.1.0.48" />

    <!-- Configuration -->
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="8.0.1" />

    <!-- Scheduling -->
    <PackageReference Include="Cronos" Version="0.8.4" />

    <!-- Logging -->
    <PackageReference Include="Serilog.AspNetCore" Version="8.0.4" />
    <PackageReference Include="Serilog.Sinks.File" Version="6.0.0" />
  </ItemGroup>

</Project>
